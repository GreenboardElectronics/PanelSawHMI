{
  "machine_name": "Panel Saw Retrofit",
  "brand": "Greenboard Electronics",
  "version": "3.1-production",
  "display": {
    "width": 1024,
    "height": 600,
    "fullscreen": true
  },
  "communication": {
    "backend": "simulate",
    "serial_port": "/dev/ttyUSB0",
    "baudrate": 115200
  },
  "safety": {
    "require_estop_ok": true,
    "require_guard_closed": true,
    "require_vacuum_ok": true
  },
  "axes": {
    "fence": {
      "axis_id": 0,
      "label": "Fence Position",
      "unit": "mm",
      "min": 0,
      "max": 3200,
      "jog_speed": 50
    },
    "height": {
      "axis_id": 1,
      "label": "Blade Height",
      "unit": "mm",
      "min": 0,
      "max": 120,
      "jog_speed": 10
    },
    "tilt": {
      "axis_id": 2,
      "label": "Blade Tilt",
      "unit": "\u00b0",
      "min": 45,
      "max": 90,
      "jog_speed": 5
    }
  }
}